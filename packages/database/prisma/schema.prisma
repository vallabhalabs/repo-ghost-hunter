generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  avatar      String?
  accessToken String?  @map("access_token")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  repositories  Repository[]
  organizations Organization[]

  @@map("users")
}

model Organization {
  id          String   @id @default(uuid()) @db.Uuid
  githubOrgId Int      @map("github_org_id")
  login       String
  avatarUrl   String?  @map("avatar_url")
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  repositories Repository[]

  // Multi-tenant uniqueness: avoid duplicates per user
  @@unique([userId, githubOrgId])
  @@unique([userId, login])
  @@index([userId])
  @@map("organizations")
}

model Repository {
  id             String   @id @default(cuid())
  githubRepoId   Int      @map("github_repo_id")
  name           String
  fullName       String   @map("full_name")
  description    String?  @db.Text
  url            String
  language       String?
  stars          Int      @default(0)
  forks          Int      @default(0)
  issues         Int      @default(0)
  lastCommitAt   DateTime? @map("last_commit_at")
  isActive       Boolean  @default(true) @map("is_active")
  healthScore    Float    @default(0) @map("health_score")
  openPrCount    Int      @default(0) @map("open_pr_count")
  openIssueCount Int      @default(0) @map("open_issue_count")
  private        Boolean  @default(false)
  defaultBranch  String   @default("main") @map("default_branch")

  userId         String    @map("user_id")
  organizationId String?   @db.Uuid @map("organization_id")

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization  Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  // Multi-tenant uniqueness: avoid duplicates per user
  @@unique([userId, githubRepoId])
  @@index([userId])
  @@index([organizationId])
  @@index([healthScore])
  @@index([githubRepoId])
  @@map("repositories")
}
